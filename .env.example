# Lead-capture email (see how much you'd save modal) — Resend
# Get a key at https://resend.com and verify your sending domain.
RESEND_API_KEY=
# Verified sender. Verify the domain you control (the site domain, joinspine.ai)
# in Resend; it need NOT match the recipients. Until verified, use the sandbox:
#   ESTIMATE_FROM="Spine <onboarding@resend.dev>"
ESTIMATE_FROM="Spine <noreply@joinspine.ai>"
# Where form submissions are emailed (comma-separated).
ESTIMATE_TO=Tech@tryheal.ai,onur@tryheal.ai

# ── Sanity (blog CMS) ──────────────────────────────────────────────
# Public (browser-safe) project coordinates.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-15
# Server-only secrets — get from `npx sanity manage` → API → Tokens.
SANITY_API_READ_TOKEN=
# Shared secret set on the Sanity webhook that triggers /api/revalidate.
SANITY_REVALIDATE_SECRET=
